# Copy to .env and adjust as needed: cp .env.example .env

# --- PostgreSQL (historical stats DB + facts log) ---
POSTGRES_USER=sportsfacts
POSTGRES_PASSWORD=sportsfacts
POSTGRES_DB=sportsfacts
POSTGRES_PORT=5432
# Connection string used by services (packages/db, ai-service)
DATABASE_URL=postgresql://sportsfacts:sportsfacts@localhost:5432/sportsfacts

# --- Redis (event/fact stream bus) ---
# Leave REDIS_URL unset to use the default in-memory bus (no Redis needed).
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# Redis stream / consumer-group names
EVENTS_STREAM=game.events
FACTS_STREAM=game.facts
AI_CONSUMER_GROUP=ai-service

# --- AI fact agent (Python LangGraph + Claude) ---
# Get a key at https://console.anthropic.com/ (prepaid credits; ~$5 is plenty).
ANTHROPIC_API_KEY=
# Hot-path model for low-latency fact generation
ANTHROPIC_MODEL=claude-sonnet-4-6
# Set this (and run the ai-service) to route the gateway's facts to the agent.
# Leave unset to use the built-in deterministic generator (no key needed).
# AI_SERVICE_URL=http://localhost:8000
