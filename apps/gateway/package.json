{
  "name": "@sportsfacts/gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify real-time gateway: replay engine + fact engine + WebSocket fan-out.",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "node --test --import tsx ./src/**/*.test.ts",
    "normalize": "tsx scripts/normalize-match.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "@sportsfacts/event-bus": "workspace:*",
    "@sportsfacts/shared-types": "workspace:*",
    "fastify": "^5.2.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
